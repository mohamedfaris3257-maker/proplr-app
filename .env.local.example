# ============================================================
# Proplr App — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose this on the client side
# Used only in server-side admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth Providers ────────────────────────────────────────────
# Configure these in: Supabase Dashboard → Authentication → Providers
# Google OAuth: https://console.cloud.google.com/
# Apple OAuth: https://developer.apple.com/

# Callback URL to register in your OAuth provider:
# http://localhost:3000/auth/callback  (development)
# https://your-domain.com/auth/callback  (production)

# ── Analytics ────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
